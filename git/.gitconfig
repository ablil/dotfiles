[user]
	email = ablil@protonmail.com
	name = ablil
[alias]
    l = log --oneline 
    la = log --all --oneline --graph
    s = status
    ss = status -s
    a = add
    au = add -u
    c = commit
    cm = commit -m
    rc = commit --amend --no-edit
    i = init
    d = diff
    ps = push
    pl = pull
[credential]
	helper = store
[core]
	editor = vi
	excludesfile = $HOME/.gitignore_global
