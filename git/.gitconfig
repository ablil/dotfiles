[user]
	email = ablil@protonmail.com
	name = ablil
[alias]
    l = log --oneline 
    lg = log --graph --abbrev-commit --decorate --format=format:'%C(bold blue)%h%C(reset) - %C(bold green)(%ar)%C(reset) %C(white)%s%C(reset) %C(dim white)- %an%C(reset)%C(bold yellow)%d%C(reset)' --all
    la = log --all --oneline --graph
    s = status
    ss = status -s
    a = add
    au = add -u
    c = commit
    cm = commit -m
    rc = commit --amend --no-edit
    i = init
    d = diff
    dh = diff HEAD
    ps = push
    psu = push -u $(git remote) $(git branch --show-current) 
    pl = pull
[core]
	editor = vi
	excludesfile = $HOME/.gitignore_global
